# ─── Supabase / Lovable Cloud ──────────────────────────────────────────
# URL do projeto (gerada automaticamente pelo Lovable Cloud)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon pública — segura para expor no frontend
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key-aqui

# ID do projeto Supabase
VITE_SUPABASE_PROJECT_ID=seu-project-id

# ─── Edge Functions (apenas servidor) ─────────────────────────────────
# Chave da Lovable AI Gateway — configure em: Lovable Cloud → Secrets
LOVABLE_API_KEY=sua-lovable-api-key

# ─── CORS ──────────────────────────────────────────────────────────────
# Domínio em produção (ex: https://meuapp.lovable.app)
# Em desenvolvimento, deixe em branco (usa * por padrão)
ALLOWED_ORIGIN=https://seu-dominio.com
