# ─── Supabase / Lovable Cloud ──────────────────────────────────────────
# URL do projeto (gerada automaticamente pelo Lovable Cloud)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon pública — segura para expor no frontend
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key-aqui

# ID do projeto Supabase
VITE_SUPABASE_PROJECT_ID=seu-project-id

# ─── IA: Groq (refine-idea, generate-prompt, review-project) ───────────
# Gratuito em: console.groq.com — tier gratuito generoso (14.400 req/dia)
# Modelos usados: llama-3.1-8b-instant, llama-3.3-70b-versatile
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─── IA: Google AI (generate-ai-content) ──────────────────────────────
# Gratuito em: aistudio.google.com/apikey — 1.500 req/dia no free tier
# Modelo usado: gemini-2.0-flash (1M de contexto!)
GOOGLE_AI_KEY=AIzaSyxxxxxxxxxxxxxxxxxx

# ─── IA: OpenAI (evaluate-project — tool calling estruturado) ──────────
# Requer créditos: platform.openai.com/api-keys
# Modelo usado: gpt-4o-mini ($0.15/1M tokens — extremamente barato)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ─── IA: Lovable Gateway (generate-screen-mockup APENAS) ───────────────
# Necessário apenas para geração de mockups visuais (imagens)
# Configurado automaticamente pelo Lovable Cloud
LOVABLE_API_KEY=sua-lovable-api-key

# ─── CORS ──────────────────────────────────────────────────────────────
# Domínio em produção (ex: https://meuapp.lovable.app)
# Em desenvolvimento, deixe em branco (usa * por padrão)
ALLOWED_ORIGIN=https://seu-dominio.com
